{
  "name": "devmind",
  "version": "0.2.0",
  "description": "AI persistent memory layer for your codebase — works with OpenAI, NVIDIA, Anthropic, or local Ollama",
  "main": "dist/cli/index.js",
  "bin": {
    "devmind": "./dist/cli/index.js"
  },
  "files": [
    "dist/",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "ts-node src/cli/index.ts",
    "start": "node dist/cli/index.js",
    "init": "ts-node src/cli/index.ts init",
    "scan": "ts-node src/cli/index.ts scan",
    "status": "ts-node src/cli/index.ts status",
    "duplicates": "ts-node src/cli/index.ts duplicates",
    "check": "ts-node src/cli/index.ts check",
    "ask": "ts-node src/cli/index.ts ask",
    "history": "ts-node src/cli/index.ts history",
    "prepublishOnly": "npm run build",
    "deploy:local": "npm run build && npm install -g ."
  },
  "keywords": [
    "ai",
    "cli",
    "developer-tools",
    "memory",
    "duplicate-detection",
    "llm",
    "ollama",
    "nvidia",
    "openai",
    "anthropic",
    "code-intelligence",
    "codebase",
    "rag"
  ],
  "author": "PRAVIN SK",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/PRAVIN-SK/devmind.git"
  },
  "bugs": {
    "url": "https://github.com/PRAVIN-SK/devmind/issues"
  },
  "homepage": "https://github.com/PRAVIN-SK/devmind#readme",
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.106.0",
    "@xenova/transformers": "^2.17.2",
    "better-sqlite3": "^12.11.1",
    "chalk": "^5.6.2",
    "commander": "^15.0.0",
    "dotenv": "^17.4.2"
  },
  "overrides": {
    "protobufjs": "7.6.5"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.13.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.8.0"
  }
}
